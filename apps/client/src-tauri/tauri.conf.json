{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Stock Box",
  "version": "0.1.0",
  "identifier": "com.stockbox.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "beforeBuildCommand": "pnpm build",
    "devUrl": "http://127.0.0.1:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Stock Box",
        "width": 1440,
        "height": 960,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "resources": [
      "binaries"
    ],
    "icon": [
      "icons/icon.png"
    ]
  }
}

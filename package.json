{
  "name": "stock-box",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.5.2",
  "workspaces": [
    "apps/client",
    "packages/contracts"
  ],
  "scripts": {
    "dev:api": "cd apps/api && uv run uvicorn app.main:app --reload",
    "dev:client": "pnpm --filter @stock-box/client dev",
    "build:client": "pnpm --filter @stock-box/client build",
    "dev:desktop": "node scripts/dev-desktop.mjs",
    "desktop:doctor": "node scripts/desktop-doctor.mjs",
    "build:api-sidecar": "node scripts/build-api-sidecar.mjs",
    "build:desktop": "node scripts/build-desktop.mjs",
    "build:desktop:windows": "node scripts/build-desktop-windows.mjs"
  }
}
